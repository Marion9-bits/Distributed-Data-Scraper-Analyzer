plugins {
    id 'java'
    id 'application'
}

group 'com.scraper'
version '1.0'

repositories {
    mavenCentral()
}

dependencies {
    implementation 'org.jsoup:jsoup:1.17.2'
    implementation 'com.squareup.okhttp3:okhttp:4.12.0'
    implementation 'com.google.code.gson:gson:2.10.1'
}

application {
    mainClass = 'com.scraper.Main'
}